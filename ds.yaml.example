cluster:
  name: dolphinscheduler-pseudo
  mode: pseudo # pseudo 或 distributed
  install_dir: /opt/ds-cli
  data_dir: /data/ds-cli
  user: dolphinscheduler
  java_home: /opt/ds-cli/java

versions:
  dolphinscheduler: 3.4.1
  zookeeper: 3.8.4
  java: "11"
  mysql_driver: 8.0.33

mysql:
  host: 127.0.0.1
  port: 3306
  database: dolphinscheduler
  username: ds_user
  password: ds_password
  server_timezone: Asia/Shanghai
  create_database: false
  # create_database 为 true 时需要本机有 mysql CLI，并填写管理员账号：
  # admin_username: root
  # admin_password: root_password

zookeeper:
  client_port: 2181
  # 分布式模式也可以复用外部 ZooKeeper；设置后 ds-cli 不会安装/启动 ZK。
  # external_connect_string: zk1:2181,zk2:2181,zk3:2181

api:
  port: 12345

services:
  api: true
  master: true
  worker: true
  alert: true

plugins:
  task: [shell, python]

env:
  # 写入 $DOLPHINSCHEDULER_HOME/bin/env/dolphinscheduler_env.sh
  # java_home 会覆盖运行时 JAVA_HOME；cluster.java_home 仍用于 ds-cli 安装/复用 JDK。
  # java_home: /data/hadoopclient/JDK/jdk1.8.0_272
  # python_launcher: /usr/bin/python3
  # hadoop_user_name: airflow
  # hadoop_home: /data/hadoopclient/HDFS/hadoop
  # path_prepend:
  #   - $HADOOP_HOME/bin
  #   - $HADOOP_HOME/sbin
  # exports:
  #   SPARK_HOME: /data/spark
  #   HIVE_HOME: /data/hive

# 分布式模式示例。取消注释后，ds-cli 会通过 SSH 在多台机器部署。
# ssh:
#   user: dolphinscheduler
#   private_key: ~/.ssh/id_rsa
#   port: 22
#   parallelism: 4
#
# hosts:
#   - { name: ds1, address: 10.0.0.1 }
#   - { name: ds2, address: 10.0.0.2 }
#   - { name: ds3, address: 10.0.0.3 }
#
# roles:
#   zookeeper: [ds1, ds2, ds3] # 未配置 external_connect_string 时必须为奇数
#   api_server: [ds1]
#   master_server: [ds1, ds2]
#   worker_server: [ds2, ds3]
#   alert_server: [ds1]
